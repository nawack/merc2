<div class="{{cssClass}}" data-application-part="form">
  <header class="armor-sheet-header">
    <img class="armor-sheet-img" src="{{item.img}}" data-edit="img" title="{{item.name}}">
    <div class="armor-sheet-title">
      <input type="text" name="name" value="{{item.name}}" placeholder="{{localize "MERC.UI.items.armorSheet.namePlaceholder"}}">
      <div class="armor-sheet-subtitle">{{localize "MERC.UI.items.armorSheet.subtitle"}}</div>
    </div>
  </header>

  <section class="armor-sheet-body">

    <!-- Champs généraux -->
    <div class="armor-main-grid">
      <div class="armor-field">
        <label>{{localize "MERC.UI.items.armorSheet.rarity"}}</label>
        <input type="text" name="system.rarity" value="{{item.system.rarity}}" placeholder="{{localize "MERC.UI.items.armorSheet.rarityPlaceholder"}}">
      </div>
      <div class="armor-field">
        <label>{{localize "MERC.UI.items.armorSheet.price"}}</label>
        <input type="text" name="system.price" value="{{item.system.price}}" placeholder="{{localize "MERC.UI.items.armorSheet.pricePlaceholder"}}">
      </div>
      <div class="armor-field">
        <label>{{localize "MERC.UI.items.armorSheet.weightKg"}}</label>
        <input type="number" name="system.weightKg" value="{{item.system.weightKg}}" min="0" step="0.1">
      </div>
      <div class="armor-field">
        <label>{{localize "MERC.UI.items.equipped"}}</label>
        <input type="checkbox" name="system.equipped" {{#if item.system.equipped}}checked{{/if}}>
      </div>
      <div class="armor-field af-span3">
        <label>{{localize "MERC.UI.items.armorSheet.description"}}</label>
        <textarea name="system.description" rows="3" placeholder="{{localize "MERC.UI.items.armorSheet.descriptionPlaceholder"}}">{{item.system.description}}</textarea>
      </div>
    </div>

    <!-- Points de blindage – schéma de corps -->
    <div class="armor-locations">
      <div class="armor-locations-header">{{localize "MERC.UI.items.armorSheet.locationsSection"}}</div>

      <div class="armor-body-diagram">

        <!-- ------------------------------------------
             CHAMPS de saisie – positionnés à gauche/droite du schéma
             ------------------------------------------ -->
        <div class="armor-inputs-left">
          <!-- Côté droit du personnage (vue de face : gauche écran) -->
          <div class="armor-inp-row" style="--row-top: 5px">
            <span class="armor-inp-label">Crâne (20)</span>
            <input type="number" name="system.locations.crane" value="{{item.system.locations.crane}}" min="0" step="1" class="armor-inp">
          </div>
          <div class="armor-inp-row" style="--row-top: 37px">
            <span class="armor-inp-label">Visage (19)</span>
            <input type="number" name="system.locations.visage" value="{{item.system.locations.visage}}" min="0" step="1" class="armor-inp">
          </div>
          <div class="armor-inp-row" style="--row-top: 69px">
            <span class="armor-inp-label">Cou (18)</span>
            <input type="number" name="system.locations.cou" value="{{item.system.locations.cou}}" min="0" step="1" class="armor-inp">
          </div>
          <div class="armor-inp-row" style="--row-top: 101px">
            <span class="armor-inp-label">Poitrine D (17)</span>
            <input type="number" name="system.locations.poitrine_dr" value="{{item.system.locations.poitrine_dr}}" min="0" step="1" class="armor-inp">
          </div>
          <div class="armor-inp-row" style="--row-top: 133px">
            <span class="armor-inp-label">Abdomen D (15)</span>
            <input type="number" name="system.locations.abdomen_dr" value="{{item.system.locations.abdomen_dr}}" min="0" step="1" class="armor-inp">
          </div>
          <div class="armor-inp-row" style="--row-top: 165px">
            <span class="armor-inp-label">Bas-ventre (13)</span>
            <input type="number" name="system.locations.bas_ventre" value="{{item.system.locations.bas_ventre}}" min="0" step="1" class="armor-inp">
          </div>
          <div class="armor-inp-row" style="--row-top: 197px">
            <span class="armor-inp-label">Bras D (12)</span>
            <input type="number" name="system.locations.bras_dr" value="{{item.system.locations.bras_dr}}" min="0" step="1" class="armor-inp">
          </div>
          <div class="armor-inp-row" style="--row-top: 229px">
            <span class="armor-inp-label">Av-bras D (8)</span>
            <input type="number" name="system.locations.av_bras_dr" value="{{item.system.locations.av_bras_dr}}" min="0" step="1" class="armor-inp">
          </div>
          <div class="armor-inp-row" style="--row-top: 261px">
            <span class="armor-inp-label">Main D (4)</span>
            <input type="number" name="system.locations.main_dr" value="{{item.system.locations.main_dr}}" min="0" step="1" class="armor-inp">
          </div>
          <div class="armor-inp-row" style="--row-top: 293px">
            <span class="armor-inp-label">Cuisse D (10)</span>
            <input type="number" name="system.locations.cuisse_dr" value="{{item.system.locations.cuisse_dr}}" min="0" step="1" class="armor-inp">
          </div>
          <div class="armor-inp-row" style="--row-top: 325px">
            <span class="armor-inp-label">Jambe D (6)</span>
            <input type="number" name="system.locations.jambe_dr" value="{{item.system.locations.jambe_dr}}" min="0" step="1" class="armor-inp">
          </div>
          <div class="armor-inp-row" style="--row-top: 357px">
            <span class="armor-inp-label">Pied D (2)</span>
            <input type="number" name="system.locations.pied_dr" value="{{item.system.locations.pied_dr}}" min="0" step="1" class="armor-inp">
          </div>
        </div>

        <!-- ------------------------------------------
             FIGURE SVG – vue de face (bonhomme)
             Viewbox : 260 x 520
             G = côté gauche de l'écran (bras droit du personnage vue de dos,
                   mais ici on affiche vue de face donc G = gauche écran)
             ------------------------------------------ -->
        <svg class="armor-body-svg" viewBox="35 0 190 390" xmlns="http://www.w3.org/2000/svg">

          <!-- Miroir horizontal : vue de face (gauche écran = bras droit du personnage) -->
          <g transform="translate(260,0) scale(-1,1)">
            <!-- -- Crâne (20) -- -->
            <ellipse class="armor-zone" data-zone="crane" cx="130" cy="32" rx="26" ry="28"/>
            <!-- -- Visage (19) -- -->
            <ellipse class="armor-zone" data-zone="visage" cx="130" cy="47" rx="20" ry="22"/>
            <!-- -- Cou (18) -- -->
            <rect class="armor-zone" data-zone="cou" x="118" y="66" width="24" height="14" rx="4"/>
            <!-- -- Poitrine G (16) -- -->
            <path class="armor-zone" data-zone="poitrine_gch" d="M88,80 L130,80 L130,122 Q108,128 88,122 Z"/>
            <!-- -- Poitrine D (17) -- -->
            <path class="armor-zone" data-zone="poitrine_dr" d="M130,80 L172,80 L172,122 Q152,128 130,122 Z"/>
            <!-- -- Abdomen G (14) -- -->
            <path class="armor-zone" data-zone="abdomen_gch" d="M92,122 Q110,132 130,130 L130,154 Q110,158 92,152 Z"/>
            <!-- -- Abdomen D (15) -- -->
            <path class="armor-zone" data-zone="abdomen_dr" d="M130,130 Q150,132 168,122 L168,152 Q150,158 130,154 Z"/>
            <!-- -- Bas-Ventre (13) -- -->
            <path class="armor-zone" data-zone="bas_ventre" d="M96,152 Q113,162 130,162 Q147,162 164,152 L162,172 Q146,180 130,180 Q114,180 98,172 Z"/>
            <!-- -- Bras G haut (11) -- -->
            <path class="armor-zone" data-zone="bras_gch" d="M62,82 Q76,78 88,82 L88,122 Q76,126 62,120 Z"/>
            <!-- -- Bras D haut (12) -- -->
            <path class="armor-zone" data-zone="bras_dr" d="M172,82 Q184,78 198,82 L198,120 Q184,126 172,122 Z"/>
            <!-- -- Av-bras G (7) -- -->
            <path class="armor-zone" data-zone="av_bras_gch" d="M56,122 Q68,118 80,122 L80,168 Q68,172 56,168 Z"/>
            <!-- -- Av-bras D (8) -- -->
            <path class="armor-zone" data-zone="av_bras_dr" d="M180,122 Q192,118 204,122 L204,168 Q192,172 180,168 Z"/>
            <!-- -- Main G (3) -- -->
            <ellipse class="armor-zone" data-zone="main_gch" cx="68" cy="182" rx="14" ry="18"/>
            <!-- -- Main D (4) -- -->
            <ellipse class="armor-zone" data-zone="main_dr" cx="192" cy="182" rx="14" ry="18"/>
            <!-- -- Cuisse G (9) -- -->
            <path class="armor-zone" data-zone="cuisse_gch" d="M100,180 Q114,176 128,178 L126,270 Q112,272 100,268 Z"/>
            <!-- -- Cuisse D (10) -- -->
            <path class="armor-zone" data-zone="cuisse_dr" d="M132,178 Q146,176 160,180 L160,268 Q148,272 134,270 Z"/>
            <!-- -- Jambe G (5) -- -->
            <path class="armor-zone" data-zone="jambe_gch" d="M100,270 Q113,266 126,270 L124,360 Q112,362 100,358 Z"/>
            <!-- -- Jambe D (6) -- -->
            <path class="armor-zone" data-zone="jambe_dr" d="M134,270 Q147,266 160,270 L160,358 Q148,362 136,360 Z"/>
            <!-- -- Pied G (1) -- -->
            <path class="armor-zone" data-zone="pied_gch" d="M98,360 Q112,356 126,360 L128,378 Q114,388 96,382 Z"/>
            <!-- -- Pied D (2) -- -->
            <path class="armor-zone" data-zone="pied_dr" d="M134,360 Q148,356 162,360 L164,382 Q146,388 132,378 Z"/>
          </g>

          <!-- Étiquettes : x = 260 - x_original (miroir) -->
          <text class="armor-zone-num" x="130" y="18">20</text>
          <text class="armor-zone-num" x="130" y="45">19</text>
          <text class="armor-zone-num" x="130" y="76">18</text>
          <text class="armor-zone-num" x="150" y="106">16</text>
          <text class="armor-zone-num" x="110" y="106">17</text>
          <text class="armor-zone-num" x="150" y="144">14</text>
          <text class="armor-zone-num" x="110" y="144">15</text>
          <text class="armor-zone-num" x="130" y="165">13</text>
          <text class="armor-zone-num" x="186" y="104">11</text>
          <text class="armor-zone-num" x="74" y="104">12</text>
          <text class="armor-zone-num" x="192" y="148">7</text>
          <text class="armor-zone-num" x="68" y="148">8</text>
          <text class="armor-zone-num" x="192" y="184">3</text>
          <text class="armor-zone-num" x="68" y="184">4</text>
          <text class="armor-zone-num" x="147" y="228">9</text>
          <text class="armor-zone-num" x="113" y="228">10</text>
          <text class="armor-zone-num" x="148" y="318">5</text>
          <text class="armor-zone-num" x="112" y="318">6</text>
          <text class="armor-zone-num" x="148" y="372">1</text>
          <text class="armor-zone-num" x="112" y="372">2</text>

        </svg>

        <div class="armor-inputs-right">
          <!-- Côté gauche du personnage (vue de face : droite écran) -->
          <div class="armor-inp-row armor-inp-row--right" style="--row-top: 101px">
            <input type="number" name="system.locations.poitrine_gch" value="{{item.system.locations.poitrine_gch}}" min="0" step="1" class="armor-inp">
            <span class="armor-inp-label">Poitrine G (16)</span>
          </div>
          <div class="armor-inp-row armor-inp-row--right" style="--row-top: 133px">
            <input type="number" name="system.locations.abdomen_gch" value="{{item.system.locations.abdomen_gch}}" min="0" step="1" class="armor-inp">
            <span class="armor-inp-label">Abdomen G (14)</span>
          </div>
          <div class="armor-inp-row armor-inp-row--right" style="--row-top: 197px">
            <input type="number" name="system.locations.bras_gch" value="{{item.system.locations.bras_gch}}" min="0" step="1" class="armor-inp">
            <span class="armor-inp-label">Bras G (11)</span>
          </div>
          <div class="armor-inp-row armor-inp-row--right" style="--row-top: 229px">
            <input type="number" name="system.locations.av_bras_gch" value="{{item.system.locations.av_bras_gch}}" min="0" step="1" class="armor-inp">
            <span class="armor-inp-label">Av-bras G (7)</span>
          </div>
          <div class="armor-inp-row armor-inp-row--right" style="--row-top: 261px">
            <input type="number" name="system.locations.main_gch" value="{{item.system.locations.main_gch}}" min="0" step="1" class="armor-inp">
            <span class="armor-inp-label">Main G (3)</span>
          </div>
          <div class="armor-inp-row armor-inp-row--right" style="--row-top: 293px">
            <input type="number" name="system.locations.cuisse_gch" value="{{item.system.locations.cuisse_gch}}" min="0" step="1" class="armor-inp">
            <span class="armor-inp-label">Cuisse G (9)</span>
          </div>
          <div class="armor-inp-row armor-inp-row--right" style="--row-top: 325px">
            <input type="number" name="system.locations.jambe_gch" value="{{item.system.locations.jambe_gch}}" min="0" step="1" class="armor-inp">
            <span class="armor-inp-label">Jambe G (5)</span>
          </div>
          <div class="armor-inp-row armor-inp-row--right" style="--row-top: 357px">
            <input type="number" name="system.locations.pied_gch" value="{{item.system.locations.pied_gch}}" min="0" step="1" class="armor-inp">
            <span class="armor-inp-label">Pied G (1)</span>
          </div>
        </div>

      </div><!-- /.armor-body-diagram -->
    </div><!-- /.armor-locations -->

  </section>
</div>
