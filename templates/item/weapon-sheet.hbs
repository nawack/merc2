<form class="{{cssClass}}" autocomplete="off" data-application-part="form">
  <header class="weapon-sheet-header">
    <img class="weapon-sheet-img" src="{{item.img}}" data-edit="img" title="{{item.name}}">
    <div class="weapon-sheet-title">
      <input type="text" name="name" value="{{item.name}}" placeholder="{{localize "MERC.UI.items.weaponSheet.namePlaceholder"}}">
      <div class="weapon-sheet-subtitle">{{localize "MERC.UI.items.weaponSheet.subtitle"}}</div>
    </div>
  </header>

  <section class="weapon-sheet-body">
    <div class="weapon-sheet-grid">
      <div class="weapon-field-group">
        <div class="weapon-field">
          <label>{{localize "MERC.UI.items.weaponSheet.subtype"}}</label>
          <select name="system.weaponSubtype" value="{{item.system.weaponSubtype}}">
            <option value="">{{localize "MERC.UI.items.weaponSheet.subtypePlaceholder"}}</option>
            <option value="melee" {{#if (eq item.system.weaponSubtype "melee")}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.subtypes.melee"}}</option>
            <option value="throwing" {{#if (eq item.system.weaponSubtype "throwing")}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.subtypes.throwing"}}</option>
            <option value="powder_projectiles" {{#if (eq item.system.weaponSubtype "powder_projectiles")}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.subtypes.powder_projectiles"}}</option>
            <option value="mechanical_projectiles" {{#if (eq item.system.weaponSubtype "mechanical_projectiles")}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.subtypes.mechanical_projectiles"}}</option>
            <option value="heavy_weapons" {{#if (eq item.system.weaponSubtype "heavy_weapons")}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.subtypes.heavy_weapons"}}</option>
            <option value="electronic_weapons" {{#if (eq item.system.weaponSubtype "electronic_weapons")}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.subtypes.electronic_weapons"}}</option>
          </select>
        </div>

        <div class="weapon-field">
          <label>{{localize "MERC.UI.items.weaponSheet.skill"}}</label>
          <select name="system.weaponSkill" value="{{item.system.weaponSkill}}">
            <option value="">{{localize "MERC.UI.items.weaponSheet.skillPlaceholder"}}</option>
            <option value="melee" {{#if (eq item.system.weaponSkill "melee")}}selected{{/if}}>{{localize "MERC.Skills.melee"}}</option>
            <option value="bladed_weapons" {{#if (eq item.system.weaponSkill "bladed_weapons")}}selected{{/if}}>{{localize "MERC.Skills.bladed_weapons"}}</option>
            <option value="mechanical_projectiles" {{#if (eq item.system.weaponSkill "mechanical_projectiles")}}selected{{/if}}>{{localize "MERC.Skills.mechanical_projectiles"}}</option>
            <option value="powder_projectiles" {{#if (eq item.system.weaponSkill "powder_projectiles")}}selected{{/if}}>{{localize "MERC.Skills.powder_projectiles"}}</option>
            <option value="throwing" {{#if (eq item.system.weaponSkill "throwing")}}selected{{/if}}>{{localize "MERC.Skills.throwing"}}</option>
            <option value="maneuvers" {{#if (eq item.system.weaponSkill "maneuvers")}}selected{{/if}}>{{localize "MERC.Skills.maneuvers"}}</option>
            <option value="heavy_weapons" {{#if (eq item.system.weaponSkill "heavy_weapons")}}selected{{/if}}>{{localize "MERC.Skills.heavy_weapons"}}</option>
            <option value="electronic_weapons" {{#if (eq item.system.weaponSkill "electronic_weapons")}}selected{{/if}}>{{localize "MERC.Skills.electronic_weapons"}}</option>
            {{#if customSpecializations.length}}
            <optgroup label="{{localize "MERC.SkillGroups.specializations"}}">
              {{#each customSpecializations as |spec|}}
              <option value="{{spec.key}}" {{#if (eq ../item.system.weaponSkill spec.key)}}selected{{/if}}>{{spec.label}}</option>
              {{/each}}
            </optgroup>
            {{/if}}
          </select>
        </div>

        <div class="weapon-field">
          <label>{{localize "MERC.UI.items.weaponSheet.proficiency"}}</label>
          <select name="system.proficiency" value="{{item.system.proficiency}}" data-dtype="Number">
            <option value="0" {{#if (eq item.system.proficiency "0")}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.proficiencyNo"}}</option>
            <option value="1" {{#if (eq item.system.proficiency "1")}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.proficiencyYes"}}</option>
          </select>
        </div>

        <div class="weapon-field">
          <label>{{localize "MERC.UI.items.weaponSheet.rarity"}}</label>
          <input type="text" name="system.rarity" value="{{item.system.rarity}}" placeholder="{{localize "MERC.UI.items.weaponSheet.rarityPlaceholder"}}">
        </div>

        <div class="weapon-field">
          <label>{{localize "MERC.UI.items.weaponSheet.price"}}</label>
          <input type="text" name="system.price" value="{{item.system.price}}" placeholder="{{localize "MERC.UI.items.weaponSheet.pricePlaceholder"}}">
        </div>
      </div>

      <div class="weapon-field-group">
        {{#if (or (eq item.system.weaponSubtype "powder_projectiles") (eq item.system.weaponSubtype "mechanical_projectiles") (eq item.system.weaponSubtype "heavy_weapons") (eq item.system.weaponSubtype "electronic_weapons"))}}
        <div class="weapon-field">
          <label>{{localize "MERC.UI.items.weaponSheet.ammoType"}}</label>
          <input type="text" name="system.ammoType" value="{{item.system.ammoType}}" placeholder="{{localize "MERC.UI.items.weaponSheet.ammoTypePlaceholder"}}">
        </div>
        <div class="weapon-field">
          <label>{{localize "MERC.UI.items.weaponSheet.magazineCapacity"}}</label>
          <input type="number" name="system.magazineCapacity" value="{{item.system.magazineCapacity}}" min="0" step="1">
        </div>
        {{/if}}

        <div class="weapon-field">
          <label>{{localize "MERC.UI.items.weaponSheet.weightKg"}}</label>
          <input type="number" name="system.weightKg" value="{{item.system.weightKg}}" min="0" step="1">
        </div>

        <div class="weapon-field weapon-field--full">
          <label>{{localize "MERC.UI.items.weaponSheet.damage"}}</label>
          <div class="weapon-damage-row">
            <input type="text" name="system.damage" value="{{item.system.damage}}" placeholder="{{localize "MERC.UI.items.weaponSheet.damagePlaceholder"}}">
            <button type="button" class="weapon-damage-roll" data-roll-formula="{{item.system.damage}}" data-roll-label="{{item.name}}" title="{{localize "MERC.UI.items.weaponSheet.rollDamage"}}">🎲</button>
          </div>
        </div>
      </div>
    </div>

    {{#if (or (eq item.system.weaponSubtype "powder_projectiles") (eq item.system.weaponSubtype "mechanical_projectiles") (eq item.system.weaponSubtype "heavy_weapons") (eq item.system.weaponSubtype "electronic_weapons"))}}
    <div class="weapon-ranges">
      <div class="weapon-ranges-header">{{localize "MERC.UI.items.weaponSheet.ranges"}}</div>
      <div class="weapon-ranges-grid">
        <div class="weapon-field">
          <label>{{localize "MERC.UI.items.weaponSheet.rangePointBlank"}}</label>
          <div class="weapon-range-input">
            <input type="number" name="system.range.pointBlank" value="{{item.system.range.pointBlank}}" min="0" step="1">
            <span class="weapon-range-unit">{{localize "MERC.UI.items.weaponSheet.rangeUnit"}}</span>
          </div>
        </div>
        <div class="weapon-field">
          <label>{{localize "MERC.UI.items.weaponSheet.rangeShort"}}</label>
          <div class="weapon-range-input">
            <input type="number" name="system.range.short" value="{{item.system.range.short}}" min="0" step="1">
            <span class="weapon-range-unit">{{localize "MERC.UI.items.weaponSheet.rangeUnit"}}</span>
          </div>
        </div>
        <div class="weapon-field">
          <label>{{localize "MERC.UI.items.weaponSheet.rangeMedium"}}</label>
          <div class="weapon-range-input">
            <input type="number" name="system.range.medium" value="{{item.system.range.medium}}" min="0" step="1">
            <span class="weapon-range-unit">{{localize "MERC.UI.items.weaponSheet.rangeUnit"}}</span>
          </div>
        </div>
        <div class="weapon-field">
          <label>{{localize "MERC.UI.items.weaponSheet.rangeLong"}}</label>
          <div class="weapon-range-input">
            <input type="number" name="system.range.long" value="{{item.system.range.long}}" min="0" step="1">
            <span class="weapon-range-unit">{{localize "MERC.UI.items.weaponSheet.rangeUnit"}}</span>
          </div>
        </div>
        <div class="weapon-field">
          <label>{{localize "MERC.UI.items.weaponSheet.rangeExtreme"}}</label>
          <div class="weapon-range-input">
            <input type="number" name="system.range.extreme" value="{{item.system.range.extreme}}" min="0" step="1">
            <span class="weapon-range-unit">{{localize "MERC.UI.items.weaponSheet.rangeUnit"}}</span>
          </div>
        </div>
      </div>
    </div>
    {{/if}}
  </section>
</form>
