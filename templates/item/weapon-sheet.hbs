<div class="{{cssClass}}" data-application-part="form">
  <header class="weapon-sheet-header">
    <img class="weapon-sheet-img" src="{{item.img}}" data-edit="img" title="{{item.name}}">
    <div class="weapon-sheet-title">
      <input type="text" name="name" value="{{item.name}}" placeholder="{{localize "MERC.UI.items.weaponSheet.namePlaceholder"}}">
      <div class="weapon-sheet-subtitle">{{localize "MERC.UI.items.weaponSheet.subtitle"}}</div>
    </div>
  </header>

  <section class="weapon-sheet-body">

    <!-- Grille principale : tous les champs en 4 colonnes -->
    <div class="weapon-main-grid">
      <div class="weapon-field wf-span2">
        <label>{{localize "MERC.UI.items.weaponSheet.subtype"}}</label>
        <select name="system.weaponSubtype" value="{{item.system.weaponSubtype}}">
          <option value="">{{localize "MERC.UI.items.weaponSheet.subtypePlaceholder"}}</option>
          <option value="melee" {{#if (eq item.system.weaponSubtype "melee")}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.subtypes.melee"}}</option>
          <option value="bladed_weapons" {{#if (eq item.system.weaponSubtype "bladed_weapons")}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.subtypes.bladed_weapons"}}</option>
          <option value="throwing" {{#if (eq item.system.weaponSubtype "throwing")}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.subtypes.throwing"}}</option>
          <option value="powder_projectiles" {{#if (eq item.system.weaponSubtype "powder_projectiles")}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.subtypes.powder_projectiles"}}</option>
          <option value="mechanical_projectiles" {{#if (eq item.system.weaponSubtype "mechanical_projectiles")}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.subtypes.mechanical_projectiles"}}</option>
          <option value="heavy_weapons" {{#if (eq item.system.weaponSubtype "heavy_weapons")}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.subtypes.heavy_weapons"}}</option>
          <option value="electronic_weapons" {{#if (eq item.system.weaponSubtype "electronic_weapons")}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.subtypes.electronic_weapons"}}</option>
        </select>
      </div>
      <div class="weapon-field wf-span2">
        <label>{{localize "MERC.UI.items.weaponSheet.skill"}}</label>
        <select name="system.weaponSkill" value="{{item.system.weaponSkill}}">
          <option value="">{{localize "MERC.UI.items.weaponSheet.skillPlaceholder"}}</option>
          <option value="melee" {{#if (eq item.system.weaponSkill "melee")}}selected{{/if}}>{{localize "MERC.Skills.melee"}}</option>
          <option value="bladed_weapons" {{#if (eq item.system.weaponSkill "bladed_weapons")}}selected{{/if}}>{{localize "MERC.Skills.bladed_weapons"}}</option>
          <option value="mechanical_projectiles" {{#if (eq item.system.weaponSkill "mechanical_projectiles")}}selected{{/if}}>{{localize "MERC.Skills.mechanical_projectiles"}}</option>
          <option value="powder_projectiles" {{#if (eq item.system.weaponSkill "powder_projectiles")}}selected{{/if}}>{{localize "MERC.Skills.powder_projectiles"}}</option>
          <option value="throwing" {{#if (eq item.system.weaponSkill "throwing")}}selected{{/if}}>{{localize "MERC.Skills.throwing"}}</option>
          <option value="maneuvers" {{#if (eq item.system.weaponSkill "maneuvers")}}selected{{/if}}>{{localize "MERC.Skills.maneuvers"}}</option>
          <option value="heavy_weapons" {{#if (eq item.system.weaponSkill "heavy_weapons")}}selected{{/if}}>{{localize "MERC.Skills.heavy_weapons"}}</option>
          <option value="electronic_weapons" {{#if (eq item.system.weaponSkill "electronic_weapons")}}selected{{/if}}>{{localize "MERC.Skills.electronic_weapons"}}</option>
          {{#if customSpecializations.length}}
          <optgroup label="{{localize "MERC.SkillGroups.specializations"}}">
            {{#each customSpecializations as |spec|}}
            <option value="{{spec.key}}" {{#if (eq ../item.system.weaponSkill spec.key)}}selected{{/if}}>{{spec.label}}</option>
            {{/each}}
          </optgroup>
          {{/if}}
        </select>
      </div>
      <div class="weapon-field">
        <label>{{localize "MERC.UI.items.weaponSheet.rarity"}}</label>
        <input type="text" name="system.rarity" value="{{item.system.rarity}}" placeholder="{{localize "MERC.UI.items.weaponSheet.rarityPlaceholder"}}">
      </div>
      <div class="weapon-field">
        <label>{{localize "MERC.UI.items.weaponSheet.price"}}</label>
        <input type="text" name="system.price" value="{{item.system.price}}" placeholder="{{localize "MERC.UI.items.weaponSheet.pricePlaceholder"}}">
      </div>
      <div class="weapon-field">
        <label>{{localize "MERC.UI.items.weaponSheet.proficiency"}}</label>
        <select name="system.proficiency" value="{{item.system.proficiency}}" data-dtype="Number">
          <option value="0" {{#if (eq item.system.proficiency 0)}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.proficiencyNo"}}</option>
          <option value="1" {{#if (eq item.system.proficiency 1)}}selected{{/if}}>{{localize "MERC.UI.items.weaponSheet.proficiencyYes"}}</option>
        </select>
      </div>
      <div class="weapon-field">
        <label>{{localize "MERC.UI.items.weaponSheet.weightKg"}}</label>
        <input type="number" name="system.weightKg" value="{{item.system.weightKg}}" min="0" step="1">
      </div>
      <div class="weapon-field">
        <label>{{localize "MERC.UI.items.equipped"}}</label>
        <input type="checkbox" name="system.equipped" {{#if item.system.equipped}}checked{{/if}}>
      </div>
      <div class="weapon-field wf-span4">
        <label>{{localize "MERC.UI.items.weaponSheet.damage"}}</label>
        <div class="weapon-damage-row">
          {{#if (or (eq item.system.weaponSubtype "melee") (eq item.system.weaponSubtype "bladed_weapons") (eq item.system.weaponSubtype "throwing"))}}
          <input type="text" name="system.damage" value="{{item.system.damage}}" placeholder="{{localize "MERC.UI.items.weaponSheet.damagePlaceholder"}}">
          {{else}}
          <input type="text" value="{{ballistics.damage}}" placeholder="—" readonly tabindex="-1">
          {{/if}}
          <button type="button" class="weapon-damage-roll" data-roll-formula="{{ballistics.damage}}" data-roll-label="{{item.name}}" title="{{localize "MERC.UI.items.weaponSheet.rollDamage"}}">🎲</button>
        </div>
      </div>
    </div>

    {{#if (or (eq item.system.weaponSubtype "powder_projectiles") (eq item.system.weaponSubtype "mechanical_projectiles") (eq item.system.weaponSubtype "heavy_weapons") (eq item.system.weaponSubtype "electronic_weapons"))}}
    <!-- Portées + Données tactiques côte à côte -->
    <div class="weapon-secondary-row">
      <div class="weapon-ranges">
        <div class="weapon-ranges-header">{{localize "MERC.UI.items.weaponSheet.ranges"}}</div>
        <div class="weapon-ranges-grid">
          <div class="weapon-field">
            <label>{{localize "MERC.UI.items.weaponSheet.rangeShort"}}</label>
            <input type="number" name="system.range.short" value="{{item.system.range.short}}" min="0" step="1">
            {{#if ballistics.hasData}}<div class="weapon-range-malus">{{#if (eq ballistics.blindage.short "-")}}<span class="weapon-range-malus-none">pas de pénétration</span>{{else}}<span class="weapon-range-malus-label">Malus Pénét.</span> {{ballistics.blindage.short}}{{/if}}</div>{{/if}}
          </div>
          <div class="weapon-field">
            <label>{{localize "MERC.UI.items.weaponSheet.rangeMedium"}}</label>
            <input type="number" name="system.range.medium" value="{{item.system.range.medium}}" min="0" step="1">
            {{#if ballistics.hasData}}<div class="weapon-range-malus">{{#if (eq ballistics.blindage.medium "-")}}<span class="weapon-range-malus-none">pas de pénétration</span>{{else}}<span class="weapon-range-malus-label">Malus Pénét.</span> {{ballistics.blindage.medium}}{{/if}}</div>{{/if}}
          </div>
          <div class="weapon-field">
            <label>{{localize "MERC.UI.items.weaponSheet.rangeLong"}}</label>
            <input type="number" name="system.range.long" value="{{item.system.range.long}}" min="0" step="1">
            {{#if ballistics.hasData}}<div class="weapon-range-malus">{{#if (eq ballistics.blindage.long "-")}}<span class="weapon-range-malus-none">pas de pénétration</span>{{else}}<span class="weapon-range-malus-label">Malus Pénét.</span> {{ballistics.blindage.long}}{{/if}}</div>{{/if}}
          </div>
          <div class="weapon-field">
            <label>{{localize "MERC.UI.items.weaponSheet.rangeExtreme"}}</label>
            <input type="number" name="system.range.extreme" value="{{item.system.range.extreme}}" min="0" step="1">
            {{#if ballistics.hasData}}<div class="weapon-range-malus">{{#if (eq ballistics.blindage.extreme "-")}}<span class="weapon-range-malus-none">pas de pénétration</span>{{else}}<span class="weapon-range-malus-label">Malus Pénét.</span> {{ballistics.blindage.extreme}}{{/if}}</div>{{/if}}
          </div>
        </div>
      </div>
      <div class="weapon-tactical">
        <div class="weapon-tactical-header">{{localize "MERC.UI.items.weaponSheet.tacticalSection"}}</div>
        <div class="weapon-tactical-grid">
          <div class="weapon-field">
            <label>{{localize "MERC.UI.items.weaponSheet.caliber"}}</label>
            <input type="text" name="system.caliber" value="{{item.system.caliber}}" placeholder="9x19">
          </div>
          <div class="weapon-field">
            <label>{{localize "MERC.UI.items.weaponSheet.barrelLength"}}</label>
            <input type="number" name="system.barrelLength" value="{{item.system.barrelLength}}" min="0" step="0.1">
          </div>
          <div class="weapon-field">
            <label>{{localize "MERC.UI.items.weaponSheet.rofMode"}}</label>
            <input type="text" name="system.rofMode" value="{{item.system.rofMode}}" placeholder="SA, FA, BA...">
          </div>
          <div class="weapon-field">
            <label>{{localize "MERC.UI.items.weaponSheet.rofLimited"}}</label>
            <input type="number" name="system.rofLimited" value="{{item.system.rofLimited}}" min="0" step="1">
          </div>
          <div class="weapon-field">
            <label>{{localize "MERC.UI.items.weaponSheet.recoilSingleShot"}}</label>
            <input type="text" name="system.recoil.singleShot" value="{{item.system.recoil.singleShot}}" placeholder="3">
          </div>
          <div class="weapon-field">
            <label>{{localize "MERC.UI.items.weaponSheet.recoilBurst"}}</label>
            <input type="text" name="system.recoil.burst" value="{{item.system.recoil.burst}}" placeholder="5">
          </div>
        </div>
      </div>
    </div>
    {{/if}}

    {{#if (or (eq item.system.weaponSubtype "powder_projectiles") (eq item.system.weaponSubtype "mechanical_projectiles") (eq item.system.weaponSubtype "heavy_weapons") (eq item.system.weaponSubtype "electronic_weapons"))}}
    <div class="weapon-ammo-section">
      <div class="weapon-ammo-header">{{localize "MERC.UI.items.weaponSheet.ammoSection"}}</div>

      {{#if (or defaultAmmo defaultAmmoName)}}
      <div class="weapon-default-ammo">
        <span class="weapon-default-ammo-label">{{localize "MERC.UI.items.weaponSheet.defaultAmmo"}}</span>
        <div class="weapon-ammo-item">
          {{#if defaultAmmo}}<img class="weapon-ammo-img" src="{{defaultAmmo.img}}" title="{{defaultAmmo.name}}" width="20" height="20">{{/if}}
          <div class="weapon-ammo-info">
            <span class="weapon-ammo-name">{{#if defaultAmmo}}{{defaultAmmo.name}}{{else}}{{defaultAmmoName}}{{/if}}</span>
            {{#if defaultAmmo}}<span class="weapon-ammo-caliber">{{defaultAmmo.system.caliber}}</span>{{/if}}
          </div>
        </div>
        <div class="weapon-ammo-stock-row">
          <div class="weapon-ammo-stock-field">
            <label>{{localize "MERC.UI.items.weaponSheet.ammoMagCapacity"}}</label>
            <input type="number" name="system.defaultAmmoMagCapacity" value="{{item.system.defaultAmmoMagCapacity}}" placeholder="{{item.system.magazine}}" min="0" step="1">
          </div>
          <div class="weapon-ammo-stock-field">
            <label>{{localize "MERC.UI.items.weaponSheet.ammoInMag"}}</label>
            <input type="number" name="system.defaultAmmoInMag" value="{{item.system.defaultAmmoInMag}}" min="0" step="1">
          </div>
          <div class="weapon-ammo-stock-field">
            <label>{{localize "MERC.UI.items.weaponSheet.ammoMagFull"}}</label>
            <input type="number" name="system.defaultAmmoMagFull" value="{{item.system.defaultAmmoMagFull}}" min="0" step="1">
          </div>
          <div class="weapon-ammo-stock-field">
            <label>{{localize "MERC.UI.items.weaponSheet.ammoMagEmpty"}}</label>
            <input type="number" name="system.defaultAmmoMagTotal" value="{{item.system.defaultAmmoMagTotal}}" min="0" step="1">
          </div>
          <div class="weapon-ammo-stock-field">
            <label>{{localize "MERC.UI.items.weaponSheet.ammoStock"}}</label>
            <input type="number" name="system.defaultAmmoStock" value="{{item.system.defaultAmmoStock}}" min="0" step="1">
          </div>
        </div>
      </div>
      {{/if}}

      <div class="weapon-ammo-list">
        {{#if ammoItems}}
          {{#each ammoItems as |ammo|}}
          <div class="weapon-ammo-item item" data-item-id="{{ammo._id}}">
            <div class="weapon-ammo-header-row">
              <div class="weapon-ammo-info">
                <span class="weapon-ammo-name">{{ammo.name}}</span>
                <span class="weapon-ammo-caliber">{{ammo.system.caliber}}</span>
              </div>
              <div class="weapon-ammo-controls">
                <button type="button" class="weapon-ammo-edit" title="Edit">✎</button>
                <button type="button" class="weapon-ammo-delete" title="Delete"><i class="fas fa-trash"></i></button>
              </div>
            </div>
            <div class="weapon-ammo-stock-row">
              <div class="weapon-ammo-stock-field">
                <label>{{localize "MERC.UI.items.weaponSheet.ammoMagCapacity"}}</label>
                <input type="number" class="ammo-field-inline" data-field="magCapacity" value="{{ammo.system.magCapacity}}" placeholder="{{item.system.magazine}}" min="0" step="1">
              </div>
              <div class="weapon-ammo-stock-field">
                <label>{{localize "MERC.UI.items.weaponSheet.ammoInMag"}}</label>
                <input type="number" class="ammo-field-inline" data-field="inMag" value="{{ammo.system.inMag}}" min="0" step="1">
              </div>
              <div class="weapon-ammo-stock-field">
                <label>{{localize "MERC.UI.items.weaponSheet.ammoMagFull"}}</label>
                <input type="number" class="ammo-field-inline" data-field="magFull" value="{{ammo.system.magFull}}" min="0" step="1">
              </div>
              <div class="weapon-ammo-stock-field">
                <label>{{localize "MERC.UI.items.weaponSheet.ammoMagEmpty"}}</label>
                <input type="number" class="ammo-field-inline" data-field="magTotal" value="{{ammo.system.magTotal}}" min="0" step="1">
              </div>
              <div class="weapon-ammo-stock-field">
                <label>{{localize "MERC.UI.items.weaponSheet.ammoStock"}}</label>
                <input type="number" class="ammo-field-inline" data-field="stock" value="{{ammo.system.stock}}" min="0" step="1">
              </div>
            </div>
          </div>
          {{/each}}
        {{else}}
          <div class="weapon-ammo-empty">{{localize "MERC.UI.items.weaponSheet.ammoNone"}}</div>
        {{/if}}
      </div>
      <button type="button" class="weapon-ammo-add btn" data-type="ammo">{{localize "MERC.UI.items.weaponSheet.addAmmo"}}</button>
    </div>
    {{/if}}

    <!-- Section Accessoires (features) -->
    <div class="weapon-feature-section">
      <div class="weapon-feature-header">{{localize "MERC.UI.items.weaponSheet.featureSection"}}</div>
      <div class="weapon-feature-list">
        {{#if featureItems}}
          {{#each featureItems as |feat|}}
          <div class="weapon-feature-item item" data-item-id="{{feat._id}}">
            <div class="weapon-feature-info">
              <div class="weapon-feature-meta">
                <span class="weapon-feature-name">{{feat.name}}</span>
                {{#if feat.system.featureType}}<span class="weapon-feature-type">{{feat.system.featureType}}</span>{{/if}}
              </div>
              <div class="weapon-feature-bonuses">
                {{#if feat.system.bonusShortRange}}<span class="wfb-tag">C: +{{feat.system.bonusShortRange}}</span>{{/if}}
                {{#if feat.system.bonusMediumRange}}<span class="wfb-tag">M: +{{feat.system.bonusMediumRange}}</span>{{/if}}
                {{#if feat.system.bonusLongRange}}<span class="wfb-tag">L: +{{feat.system.bonusLongRange}}</span>{{/if}}
                {{#if feat.system.bonusExtremeRange}}<span class="wfb-tag">X: +{{feat.system.bonusExtremeRange}}</span>{{/if}}
                {{#if feat.system.noiseReduction}}<span class="wfb-tag wfb-noise">🔇 {{feat.system.noiseReduction}}</span>{{/if}}
                {{#if feat.system.lateralNoiseReduction}}<span class="wfb-tag wfb-noise">🔇↔ {{feat.system.lateralNoiseReduction}}</span>{{/if}}
                {{#if feat.system.lengthIncreaseCm}}<span class="wfb-tag wfb-len">+{{feat.system.lengthIncreaseCm}}cm</span>{{/if}}
              </div>
            </div>
            <div class="weapon-feature-controls">
              <button type="button" class="weapon-feature-edit" title="Edit">✎</button>
              <button type="button" class="weapon-feature-delete" title="Delete"><i class="fas fa-trash"></i></button>
            </div>
          </div>
          {{/each}}
        {{else}}
          <div class="weapon-feature-empty">{{localize "MERC.UI.items.weaponSheet.featureNone"}}</div>
        {{/if}}
      </div>
      <button type="button" class="weapon-feature-add btn">{{localize "MERC.UI.items.weaponSheet.addFeature"}}</button>
    </div>

  </section>
</div>
