<div class="{{cssClass}}">
  <!-- HEADER -->
  <div class="sheet-header">
    <div class="header-columns">
      <!-- Left Column: Character Image -->
      <div class="header-image-column">
        <div class="portrait-container">
          <img class="character-portrait" src="{{actor.img}}" alt="{{actor.name}}" title="{{localize "MERC.UI.biography.imageTitle"}}">
          <div class="portrait-overlay">
            <button type="button" class="portrait-browse-btn" title="{{localize "MERC.UI.biography.chooseImage"}}">
              <i class="fas fa-folder-open"></i>
            </button>
          </div>
        </div>
      </div>
      
      <!-- Right Column: Character Info + Tabs -->
      <div class="header-info-column">
        <div class="header-info-and-tabs">
          <!-- Block 1: Header Info (photo removed) -->
          <div class="header-info-block">
            <!-- Row 1: Name + Gender -->
            <div class="header-info-row header-row-1">
              <div class="field-name-large">
                <input type="text" name="name" value="{{actor.name}}" placeholder="{{localize "MERC.UI.biography.namePlaceholder"}}">
              </div>
              <div class="field-inline field-gender">
                <div class="gender-toggle">
                  <label class="gender-option male" title="{{localize "MERC.UI.gender.male"}}">
                    <input type="radio" name="system.biography.gender" value="male" {{#eq actor.system.biography.gender "male"}}checked{{/eq}}>
                    <span class="gender-icon" aria-hidden="true"></span>
                  </label>
                  <label class="gender-option female" title="{{localize "MERC.UI.gender.female"}}">
                    <input type="radio" name="system.biography.gender" value="female" {{#eq actor.system.biography.gender "female"}}checked{{/eq}}>
                    <span class="gender-icon" aria-hidden="true"></span>
                  </label>
                </div>
              </div>
            </div>
            
            <!-- Row 2: Age + Taille + Poids -->
            <div class="header-info-row header-row-2">
              <div class="field-inline">
                <label>{{localize "MERC.UI.biography.age"}}</label>
                <input type="text" name="system.biography.age" value="{{actor.system.biography.age}}" placeholder="{{localize "MERC.UI.biography.agePlaceholder"}}">
              </div>
              <div class="field-inline">
                <label>{{localize "MERC.UI.biography.height"}}</label>
                <input type="number" name="system.biography.height" value="{{actor.system.biography.height}}" min="0" placeholder="{{localize "MERC.UI.biography.heightPlaceholder"}}">
              </div>
              <div class="field-inline">
                <label>{{localize "MERC.UI.biography.weight"}}</label>
                <input type="number" name="system.biography.weight" value="{{actor.system.biography.weight}}" min="0" placeholder="{{localize "MERC.UI.biography.weightPlaceholder"}}">
              </div>
            </div>
            
            <!-- Row 3: Année + Origine + Renommé -->
            <div class="header-info-row header-row-3">
              <div class="field-inline">
                <label>{{localize "MERC.UI.biography.year"}}</label>
                <input type="number" name="system.biography.year" value="{{actor.system.biography.year}}" min="0" placeholder="{{localize "MERC.UI.biography.yearPlaceholder"}}">
              </div>
              <div class="field-inline">
                <label>{{localize "MERC.UI.biography.origin"}}</label>
                <input type="text" name="system.biography.origin" value="{{actor.system.biography.origin}}" placeholder="{{localize "MERC.UI.biography.originPlaceholder"}}">
              </div>
              <div class="field-inline">
                <label>{{localize "MERC.UI.biography.renown"}}</label>
                <input type="number" name="system.biography.renown" value="{{actor.system.biography.renown}}" min="0" placeholder="{{localize "MERC.UI.biography.renownPlaceholder"}}">
              </div>
            </div>
          </div>

          <!-- Block 2: Navigation Tabs -->
          <nav class="sheet-tabs tabs" data-group="primary">
            {{#if isLimited}}
              <a class="item active" data-tab="description">{{localize "MERC.Labels.description"}}</a>
            {{else}}
              <a class="item active" data-tab="stats">{{localize "MERC.UI.tabs.attributes"}}</a>
              <a class="item" data-tab="skills">{{localize "MERC.UI.tabs.skills"}}</a>
              <a class="item" data-tab="combat">{{localize "MERC.UI.tabs.combat"}}</a>
              <a class="item" data-tab="items">{{localize "MERC.UI.tabs.items"}}</a>
              <a class="item" data-tab="sante">{{localize "MERC.UI.tabs.health"}}</a>
              <a class="item" data-tab="description">{{localize "MERC.Labels.description"}}</a>
              <a class="item" data-tab="notes">{{localize "MERC.Labels.notes"}}</a>
            {{/if}}
          </nav>
        </div>
      </div>
    </div>
  </div>

  <!-- TAB CONTENT -->
  <section class="sheet-body">
    
    <!-- STATS TAB -->
    <div class="tab-content{{#unless isLimited}} active{{/unless}}" data-tab="stats">
      
      <!-- Attributes Grid - Custom Style -->
      <div class="headerActorsAttribs three-columns">
        <div class="attrib-column">
          <div class="attrib-column-headers">
            <span class="attrib-name-header"></span>
            <div class="attrib-values-headers">
              <span class="attrib-value-header">{{localize "MERC.UI.attributes.origin"}}</span>
              <span class="attrib-value-header">{{localize "MERC.UI.attributes.current"}}</span>
            </div>
          </div>
          <div class="headerActorAttrib" data-ability="intelligence">
            <span class="headerActorAttribLabel">{{localize "MERC.Abilities.intelligence"}}</span>
            <div class="attrib-values">
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.intelligence.origin" value="{{actor.system.attributes.intelligence.origin}}" min="0" max="10" step="1">
              </div>
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.intelligence.current" value="{{actor.system.attributes.intelligence.current}}" min="0" max="10" step="1">
              </div>
            </div>
          </div>

          <div class="headerActorAttrib" data-ability="will">
            <span class="headerActorAttribLabel">{{localize "MERC.Abilities.will"}}</span>
            <div class="attrib-values">
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.will.origin" value="{{actor.system.attributes.will.origin}}" min="0" max="10" step="1">
              </div>
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.will.current" value="{{actor.system.attributes.will.current}}" min="0" max="10" step="1">
              </div>
            </div>
          </div>

          <div class="headerActorAttrib" data-ability="mental">
            <span class="headerActorAttribLabel">{{localize "MERC.Abilities.mental"}}</span>
            <div class="attrib-values">
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.mental.origin" value="{{actor.system.attributes.mental.origin}}" min="0" max="10" step="1">
              </div>
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.mental.current" value="{{actor.system.attributes.mental.current}}" min="0" max="10" step="1">
              </div>
            </div>
          </div>

          <div class="headerActorAttrib" data-ability="charisma">
            <span class="headerActorAttribLabel">{{localize "MERC.Abilities.charisma"}}</span>
            <div class="attrib-values">
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.charisma.origin" value="{{actor.system.attributes.charisma.origin}}" min="0" max="10" step="1">
              </div>
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.charisma.current" value="{{actor.system.attributes.charisma.current}}" min="0" max="10" step="1">
              </div>
            </div>
          </div>

          <div class="headerActorAttrib" data-ability="adaptation">
            <span class="headerActorAttribLabel">{{localize "MERC.Abilities.adaptation"}}</span>
            <div class="attrib-values">
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.adaptation.origin" value="{{actor.system.attributes.adaptation.origin}}" min="0" max="10" step="1">
              </div>
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.adaptation.current" value="{{actor.system.attributes.adaptation.current}}" min="0" max="10" step="1">
              </div>
            </div>
          </div>
        </div>

        <div class="attrib-column">
          <div class="attrib-column-headers">
            <span class="attrib-name-header"></span>
            <div class="attrib-values-headers">
              <span class="attrib-value-header">{{localize "MERC.UI.attributes.origin"}}</span>
              <span class="attrib-value-header">{{localize "MERC.UI.attributes.current"}}</span>
            </div>
          </div>
          <div class="headerActorAttrib" data-ability="strength">
            <span class="headerActorAttribLabel">{{localize "MERC.Abilities.strength"}}</span>
            <div class="attrib-values">
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.strength.origin" value="{{actor.system.attributes.strength.origin}}" min="0" max="10" step="1">
              </div>
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.strength.current" value="{{actor.system.attributes.strength.current}}" min="0" max="10" step="1">
              </div>
            </div>
          </div>

          <div class="headerActorAttrib" data-ability="dexterity">
            <span class="headerActorAttribLabel">{{localize "MERC.Abilities.dexterity"}}</span>
            <div class="attrib-values">
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.dexterity.origin" value="{{actor.system.attributes.dexterity.origin}}" min="0" max="10" step="1">
              </div>
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.dexterity.current" value="{{actor.system.attributes.dexterity.current}}" min="0" max="10" step="1">
              </div>
            </div>
          </div>

          <div class="headerActorAttrib" data-ability="speed">
            <span class="headerActorAttribLabel">{{localize "MERC.Abilities.speed"}}</span>
            <div class="attrib-values">
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.speed.origin" value="{{actor.system.attributes.speed.origin}}" min="0" max="10" step="1">
              </div>
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.speed.current" value="{{actor.system.attributes.speed.current}}" min="0" max="10" step="1">
              </div>
            </div>
          </div>

          <div class="headerActorAttrib" data-ability="constitution">
            <span class="headerActorAttribLabel">{{localize "MERC.Abilities.constitution"}}</span>
            <div class="attrib-values">
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.constitution.origin" value="{{actor.system.attributes.constitution.origin}}" min="0" max="10" step="1">
              </div>
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.constitution.current" value="{{actor.system.attributes.constitution.current}}" min="0" max="10" step="1">
              </div>
            </div>
          </div>

          <div class="headerActorAttrib" data-ability="chance">
            <span class="headerActorAttribLabel">{{localize "MERC.Abilities.chance"}}</span>
            <div class="attrib-values">
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.chance.origin" value="{{actor.system.attributes.chance.origin}}" min="0" max="10" step="1">
              </div>
              <div class="attrib-value">
                <input type="number" class="headerActorAttribValue" name="system.attributes.chance.current" value="{{actor.system.attributes.chance.current}}" min="0" max="10" step="1">
              </div>
            </div>
          </div>
        </div>

        <div class="attrib-column">
          <div class="attrib-column-headers is-ghost-header">
            <span class="attrib-name-header"></span>
            <div class="attrib-values-headers">
              <span class="attrib-value-header">{{localize "MERC.UI.attributes.origin"}}</span>
              <span class="attrib-value-header">{{localize "MERC.UI.attributes.current"}}</span>
            </div>
          </div>
          <div class="headerActorAttrib perception-attrib" data-ability="perception">
            <div class="perception-header">
              <span class="headerActorAttribLabel">{{localize "MERC.Abilities.perception"}}</span>
              <input type="number" class="headerActorAttribValue" name="system.attributes.perception" value="{{actor.system.attributes.perception}}" min="0" max="10" step="1">
            </div>
            <div class="headerActorSubAttrib" data-sub-ability="sight" data-label="Vue">
              <span class="headerActorSubAttribLabel">{{localize "MERC.UI.perception.sight"}}</span>
              <input type="number" class="headerActorAttribValue" name="system.attributes.perceptionDetail.sight" value="{{actor.system.attributes.perceptionDetail.sight}}" min="0" max="10" step="1">
            </div>
            <div class="headerActorSubAttrib" data-sub-ability="hearing" data-label="Ouie">
              <span class="headerActorSubAttribLabel">{{localize "MERC.UI.perception.hearing"}}</span>
              <input type="number" class="headerActorAttribValue" name="system.attributes.perceptionDetail.hearing" value="{{actor.system.attributes.perceptionDetail.hearing}}" min="0" max="10" step="1">
            </div>
            <div class="headerActorSubAttrib" data-sub-ability="taste" data-label="Goût">
              <span class="headerActorSubAttribLabel">{{localize "MERC.UI.perception.taste"}}</span>
              <input type="number" class="headerActorAttribValue" name="system.attributes.perceptionDetail.taste" value="{{actor.system.attributes.perceptionDetail.taste}}" min="0" max="10" step="1">
            </div>
            <div class="headerActorSubAttrib" data-sub-ability="smell" data-label="Odorat">
              <span class="headerActorSubAttribLabel">{{localize "MERC.UI.perception.smell"}}</span>
              <input type="number" class="headerActorAttribValue" name="system.attributes.perceptionDetail.smell" value="{{actor.system.attributes.perceptionDetail.smell}}" min="0" max="10" step="1">
            </div>
            <div class="headerActorSubAttrib" data-sub-ability="touch" data-label="Toucher">
              <span class="headerActorSubAttribLabel">{{localize "MERC.UI.perception.touch"}}</span>
              <input type="number" class="headerActorAttribValue" name="system.attributes.perceptionDetail.touch" value="{{actor.system.attributes.perceptionDetail.touch}}" min="0" max="10" step="1">
            </div>
          </div>
        </div>
      </div>

      <!-- Stat Grid-->
      <div class="headerStatsGrid three-columns">
        
        <!-- COLUMN 1: Physical Characteristics -->
        <div class="stats-column">
          <div class="stats-column-headers">
            <span class="stats-name-header">{{localize "MERC.UI.stats.physical"}}</span>
          </div>
          
          <div class="headerStat" data-stat="endurance">
            <span class="headerStatLabel">{{localize "MERC.UI.stats.endurance"}}</span>
            <div class="stat-values">
              <div class="stat-display">
                <div class="stat-value-large">{{actor.system.combat.endurance}}</div>
              </div>
            </div>
          </div>

          <div class="headerStat" data-stat="pointCorporence">
            <span class="headerStatLabel">{{localize "MERC.UI.stats.bodyPoints"}}</span>
            <div class="stat-values">
              <div class="stat-display">
                <div class="stat-value-large">{{actor.system.combat.pointCorporence}}</div>
              </div>
            </div>
          </div>

          <div class="headerStat" data-stat="capaciteCharge">
            <span class="headerStatLabel">{{localize "MERC.UI.stats.carryCapacity"}}</span>
            <div class="stat-values">
              <div class="stat-display">
                <div class="stat-value-large">{{actor.system.combat.capaciteCharge}}</div>
              </div>
            </div>
          </div>

          <div class="headerStat" data-stat="encombrement">
            <span class="headerStatLabel">{{localize "MERC.UI.stats.burden"}}</span>
            <div class="stat-values">
              <div class="stat-display">
                <div class="stat-value-large burden-display" id="total-weight">0</div>
              </div>
            </div>
          </div>
        </div>

        <!-- COLUMN 2: Bonuses -->
        <div class="stats-column">
          <div class="stats-column-headers">
            <span class="stats-name-header">{{localize "MERC.UI.stats.combatBonuses"}}</span>
          </div>

          <div class="headerStat" data-stat="bonusDiscretion">
            <span class="headerStatLabel">{{localize "MERC.UI.stats.stealthBonus"}}</span>
            <div class="stat-values">
              <div class="stat-display">
                <div class="stat-value-large">{{actor.system.combat.bonusDiscretion}}</div>
              </div>
            </div>
          </div>

          <div class="headerStat" data-stat="bonusDissimulation">
            <span class="headerStatLabel">{{localize "MERC.UI.stats.concealmentBonus"}}</span>
            <div class="stat-values">
              <div class="stat-display">
                <div class="stat-value-large">{{actor.system.combat.bonusDissimulation}}</div>
              </div>
            </div>
          </div>
        </div>

        <!-- COLUMN 3: Movement Speeds -->
        <div class="stats-column">
          <div class="stats-column-headers">
            <span class="stats-name-header">{{localize "MERC.UI.stats.movementSpeeds"}}</span>
          </div>

          <div class="headerStat" data-stat="reptation">
            <span class="headerStatLabel">{{localize "MERC.UI.stats.reptation"}}</span>
            <div class="stat-values">
              <div class="stat-display">
                <div class="stat-value-large">{{actor.system.movement.reptation}}</div>
              </div>
              <div class="stat-display burden-speed" id="speed-reptation-actual">
                <div class="stat-value-large burden-speed">-</div>
              </div>
            </div>
          </div>

          <div class="headerStat" data-stat="marche">
            <span class="headerStatLabel">{{localize "MERC.UI.stats.walk"}}</span>
            <div class="stat-values">
              <div class="stat-display">
                <div class="stat-value-large">{{actor.system.movement.marche}}</div>
              </div>
              <div class="stat-display burden-speed" id="speed-marche-actual">
                <div class="stat-value-large burden-speed">-</div>
              </div>
            </div>
          </div>

          <div class="headerStat" data-stat="course">
            <span class="headerStatLabel">{{localize "MERC.UI.stats.run"}}</span>
            <div class="stat-values">
              <div class="stat-display">
                <div class="stat-value-large">{{actor.system.movement.course}}</div>
              </div>
              <div class="stat-display burden-speed" id="speed-course-actual">
                <div class="stat-value-large burden-speed">-</div>
              </div>
            </div>
          </div>
        </div>

      </div>

    </div>

    <!-- SKILLS TAB -->
    <div class="tab-content" data-tab="skills">
      
      <div class="skills-section">
        <nav class="skills-tabs">
          {{#each skillGroups as |group|}}
            <a class="item {{#if @first}}active{{/if}}" data-tab="{{group.id}}">{{group.label}}</a>
          {{/each}}
        </nav>
        <section class="skills-tabs-body">
          {{#each skillGroups as |group|}}
          <div class="skills-tab-content {{#if @first}}active{{/if}}" data-tab="{{group.id}}">
            
            <div class="skills-two-columns">
              <!-- Column 1 -->
              <div class="skills-column">
                <div class="skills-column-headers">
                  <div class="skill-name-header"></div>
                  <div class="skill-values-headers">
                    <div class="skill-value-header">{{localize "MERC.UI.skills.base"}}</div>
                    <div class="skill-value-header">{{localize "MERC.UI.skills.dev"}}</div>
                    <div class="skill-value-header">{{localize "MERC.UI.skills.degree"}}</div>
                    <div class="skill-value-header">{{localize "MERC.UI.skills.bonus"}}</div>
                    <div class="skill-value-header">{{localize "MERC.UI.skills.total"}}</div>
                  </div>
                </div>
                
                <div class="skills-list">
                  {{#each group.skills as |skill|}}
                    {{#if (eq (mod @index 2) 0)}}
                    <div class="skill-item {{#unless skill.unlocked}}locked{{/unless}}" data-skill="{{skill.key}}"{{#if skill.isCustomLanguage}} data-language-name="{{skill.customLanguageName}}"{{/if}}{{#if skill.isCustomSpecialization}} data-specialization-name="{{skill.customSpecializationName}}"{{/if}}>
                      {{#if skill.isCustomSpecialization}}
                      <div class="specialization-base-skill-wrapper">
                        <select class="specialization-base-skill-select" data-specialization-name="{{skill.customSpecializationName}}">
                          <option value="">-- {{localize "MERC.UI.skills.baseSkillLabel"}} --</option>
                          {{#each @root.allBaseSkills as |baseSkill|}}
                          <option value="{{baseSkill.key}}" {{#if (eq baseSkill.key skill.customSpecializationBaseSkill)}}selected{{/if}}>{{baseSkill.label}}</option>
                          {{/each}}
                        </select>
                      </div>
                      {{/if}}
                      <div class="skill-name" title="{{skill.displayLabel}}">
                        {{#if skill.isCustomLanguage}}
                        <span class="custom-language-label">{{localize "MERC.UI.skills.languageLabel"}}:</span>
                        <input type="text" class="language-name-edit" value="{{skill.customLanguageName}}" title="{{localize "MERC.UI.skills.languageLabel"}}">
                        {{else if skill.isNativeLanguage}}
                        <span class="custom-language-label">{{localize "MERC.Skills.language_native"}}:</span>
                        <input type="text" class="native-language-edit" name="system.skills.language_native.name" value="{{skill.nativeLanguageName}}" title="{{localize "MERC.Skills.language_native"}}">
                        {{else if skill.isCustomSpecialization}}
                        <span class="specialization-separator">{{localize "MERC.Labels.specializationPrefix"}} </span>
                        <input type="text" class="specialization-name-edit" value="{{skill.customSpecializationName}}" title="{{localize "MERC.Labels.specializationPrefix"}}">
                        {{else}}
                        {{skill.displayLabel}}
                        {{#unless skill.unlocked}}<i class="fas fa-lock" title="{{localize "MERC.UI.skills.missingPrereqs"}}: {{skill.missingPrereqsText}}"></i>{{/unless}}
                        {{/if}}
                      </div>
                      <div class="skill-value">
                        <div class="skill-inputs">
                          <input type="number" class="skill-input" name="system.skills.{{skill.key}}.base" value="{{skill.base}}" min="0" title="{{#if skill.baseTooltip}}{{skill.baseTooltip}}{{else}}{{localize "MERC.UI.skills.base"}}{{/if}}" readonly>
                          {{#if skill.isCustomLanguage}}
                          <input type="number" class="skill-input" name="system.customLanguages.{{skill.customLanguageName}}.dev" value="{{skill.dev}}" min="0" title="{{#if skill.devTooltip}}{{skill.devTooltip}}{{else}}{{localize "MERC.UI.skills.dev"}}{{/if}}">
                          {{else if skill.isCustomSpecialization}}
                          <input type="number" class="skill-input" name="system.customSpecializations.{{skill.customSpecializationName}}.dev" value="{{skill.dev}}" min="0" title="{{#if skill.devTooltip}}{{skill.devTooltip}}{{else}}{{localize "MERC.UI.skills.dev"}}{{/if}}">
                          {{else}}
                          <input type="number" class="skill-input" name="system.skills.{{skill.key}}.dev" value="{{skill.dev}}" min="0" title="{{#if skill.devTooltip}}{{skill.devTooltip}}{{else}}{{localize "MERC.UI.skills.dev"}}{{/if}}" {{#unless skill.unlocked}}disabled{{/unless}}>
                          {{/if}}
                          <input type="number" class="skill-input" name="system.skills.{{skill.key}}.degree" value="{{skill.degree}}" min="0" title="{{localize "MERC.UI.skills.degree"}}" readonly>
                          {{#if skill.isCustomLanguage}}
                          <input type="number" class="skill-input" name="system.customLanguages.{{skill.customLanguageName}}.bonus" value="{{skill.bonus}}" min="0" title="{{localize "MERC.UI.skills.bonus"}}">
                          {{else if skill.isCustomSpecialization}}
                          <input type="number" class="skill-input" name="system.customSpecializations.{{skill.customSpecializationName}}.bonus" value="{{skill.bonus}}" min="0" title="{{localize "MERC.UI.skills.bonus"}}">
                          {{else}}
                          <input type="number" class="skill-input" name="system.skills.{{skill.key}}.bonus" value="{{skill.bonus}}" min="0" title="{{localize "MERC.UI.skills.bonus"}}" {{#unless skill.unlocked}}disabled{{/unless}}>
                          {{/if}}
                        </div>
                        <button type="button" class="skill-roll-btn" {{#unless skill.unlocked}}disabled{{/unless}}>{{#if (gt skill.total 0)}}+{{/if}}{{skill.total}}</button>
                        {{#if skill.isCustomLanguage}}
                        <button type="button" class="btn-remove-language" title="{{localize "MERC.UI.skills.removeCustomLanguage"}}"><i class="fas fa-trash"></i></button>
                        {{else if skill.isCustomSpecialization}}
                        <button type="button" class="btn-remove-specialization" title="{{localize "MERC.UI.skills.removeCustomSpecialization"}}"><i class="fas fa-trash"></i></button>
                        {{/if}}
                      </div>
                    </div>
                    {{/if}}
                  {{/each}}
                </div>
              </div>
              
              <!-- Column 2 -->
              <div class="skills-column">
                <div class="skills-column-headers">
                  <div class="skill-name-header"></div>
                  <div class="skill-values-headers">
                    <div class="skill-value-header">{{localize "MERC.UI.skills.base"}}</div>
                    <div class="skill-value-header">{{localize "MERC.UI.skills.dev"}}</div>
                    <div class="skill-value-header">{{localize "MERC.UI.skills.degree"}}</div>
                    <div class="skill-value-header">{{localize "MERC.UI.skills.bonus"}}</div>
                    <div class="skill-value-header">{{localize "MERC.UI.skills.total"}}</div>
                  </div>
                </div>
                
                <div class="skills-list">
                  {{#each group.skills as |skill|}}
                    {{#unless (eq (mod @index 2) 0)}}
                    <div class="skill-item {{#unless skill.unlocked}}locked{{/unless}}" data-skill="{{skill.key}}"{{#if skill.isCustomLanguage}} data-language-name="{{skill.customLanguageName}}"{{/if}}{{#if skill.isCustomSpecialization}} data-specialization-name="{{skill.customSpecializationName}}"{{/if}}>
                      {{#if skill.isCustomSpecialization}}
                      <div class="specialization-base-skill-wrapper">
                        <select class="specialization-base-skill-select" data-specialization-name="{{skill.customSpecializationName}}">
                          <option value="">-- {{localize "MERC.UI.skills.baseSkillLabel"}} --</option>
                          {{#each @root.allBaseSkills as |baseSkill|}}
                          <option value="{{baseSkill.key}}" {{#if (eq baseSkill.key skill.customSpecializationBaseSkill)}}selected{{/if}}>{{baseSkill.label}}</option>
                          {{/each}}
                        </select>
                      </div>
                      {{/if}}
                      <div class="skill-name" title="{{skill.displayLabel}}">
                        {{#if skill.isCustomLanguage}}
                        <span class="custom-language-label">{{localize "MERC.UI.skills.languageLabel"}}:</span>
                        <input type="text" class="language-name-edit" value="{{skill.customLanguageName}}" title="{{localize "MERC.UI.skills.languageLabel"}}">
                        {{else if skill.isNativeLanguage}}
                        <span class="custom-language-label">{{localize "MERC.Skills.language_native"}}:</span>
                        <input type="text" class="native-language-edit" name="system.skills.language_native.name" value="{{skill.nativeLanguageName}}" title="{{localize "MERC.Skills.language_native"}}">
                        {{else if skill.isCustomSpecialization}}
                        <span class="specialization-separator">{{localize "MERC.Labels.specializationPrefix"}} </span>
                        <input type="text" class="specialization-name-edit" value="{{skill.customSpecializationName}}" title="{{localize "MERC.Labels.specializationPrefix"}}">
                        {{else}}
                        {{skill.displayLabel}}
                        {{#unless skill.unlocked}}<i class="fas fa-lock" title="{{localize "MERC.UI.skills.missingPrereqs"}}: {{skill.missingPrereqsText}}"></i>{{/unless}}
                        {{/if}}
                      </div>
                      <div class="skill-value">
                        <div class="skill-inputs">
                          <input type="number" class="skill-input" name="system.skills.{{skill.key}}.base" value="{{skill.base}}" min="0" title="{{#if skill.baseTooltip}}{{skill.baseTooltip}}{{else}}{{localize "MERC.UI.skills.base"}}{{/if}}" readonly>
                          {{#if skill.isCustomLanguage}}
                          <input type="number" class="skill-input" name="system.customLanguages.{{skill.customLanguageName}}.dev" value="{{skill.dev}}" min="0" title="{{#if skill.devTooltip}}{{skill.devTooltip}}{{else}}{{localize "MERC.UI.skills.dev"}}{{/if}}">
                          {{else if skill.isCustomSpecialization}}
                          <input type="number" class="skill-input" name="system.customSpecializations.{{skill.customSpecializationName}}.dev" value="{{skill.dev}}" min="0" title="{{#if skill.devTooltip}}{{skill.devTooltip}}{{else}}{{localize "MERC.UI.skills.dev"}}{{/if}}">
                          {{else}}
                          <input type="number" class="skill-input" name="system.skills.{{skill.key}}.dev" value="{{skill.dev}}" min="0" title="{{#if skill.devTooltip}}{{skill.devTooltip}}{{else}}{{localize "MERC.UI.skills.dev"}}{{/if}}" {{#unless skill.unlocked}}disabled{{/unless}}>
                          {{/if}}
                          <input type="number" class="skill-input" name="system.skills.{{skill.key}}.degree" value="{{skill.degree}}" min="0" title="{{localize "MERC.UI.skills.degree"}}" readonly>
                          {{#if skill.isCustomLanguage}}
                          <input type="number" class="skill-input" name="system.customLanguages.{{skill.customLanguageName}}.bonus" value="{{skill.bonus}}" min="0" title="{{localize "MERC.UI.skills.bonus"}}">
                          {{else if skill.isCustomSpecialization}}
                          <input type="number" class="skill-input" name="system.customSpecializations.{{skill.customSpecializationName}}.bonus" value="{{skill.bonus}}" min="0" title="{{localize "MERC.UI.skills.bonus"}}">
                          {{else}}
                          <input type="number" class="skill-input" name="system.skills.{{skill.key}}.bonus" value="{{skill.bonus}}" min="0" title="{{localize "MERC.UI.skills.bonus"}}" {{#unless skill.unlocked}}disabled{{/unless}}>
                          {{/if}}
                        </div>
                        <button type="button" class="skill-roll-btn" {{#unless skill.unlocked}}disabled{{/unless}}>{{#if (gt skill.total 0)}}+{{/if}}{{skill.total}}</button>
                        {{#if skill.isCustomLanguage}}
                        <button type="button" class="btn-remove-language" title="{{localize "MERC.UI.skills.removeCustomLanguage"}}"><i class="fas fa-trash"></i></button>
                        {{else if skill.isCustomSpecialization}}
                        <button type="button" class="btn-remove-specialization" title="{{localize "MERC.UI.skills.removeCustomSpecialization"}}"><i class="fas fa-trash"></i></button>
                        {{/if}}
                      </div>
                    </div>
                    {{/unless}}
                  {{/each}}
                </div>
              </div>
            </div>
            {{#if (eq group.id "languages")}}
            <div class="custom-languages-footer">
              <button type="button" class="btn-add-language btn">+ {{localize "MERC.UI.skills.addCustomLanguage"}}</button>
            </div>
            {{/if}}
            {{#if (eq group.id "specializations")}}
            <div class="custom-specializations-footer">
              <button type="button" class="btn-add-specialization btn">+ {{localize "MERC.UI.skills.addCustomSpecialization"}}</button>
            </div>
            {{/if}}
          </div>
          {{/each}}
        </section>
      </div>

    </div>

    <!-- COMBAT TAB -->
    <div class="tab-content" data-tab="combat">

      <!-- Combat Sub-tab Navigation -->
      <nav class="combat-subtabs">
        <a class="item active" data-tab="combat-base">{{localize "MERC.UI.combat.baseDamageHeader"}}</a>
        {{#each (filterItems actor.items "weapon") as |item|}}
        <a class="item" data-tab="combat-weapon-{{item._id}}">{{item.name}}{{#if (eq item.system.proficiency 1)}}<span class="proficiency-star">★</span>{{/if}}</a>
        {{/each}}
      </nav>

      <!-- Combat Sub-tab Body -->
      <section class="combat-subtabs-body">

        <!-- Base Combat Tab -->
        <div class="combat-subtab-content active" data-tab="combat-base">
          <!-- Base Damage -->
          <div class="combat-base-damage-section">
            <div class="combat-base-damage-grid">
              <div class="combat-base-damage-row">
                <div class="combat-base-damage-label">
                  <span class="combat-base-damage-title">{{localize "MERC.UI.combat.baseDamageMelee"}}</span>
                  <span class="combat-base-damage-skill">{{localize "MERC.UI.combat.linkedSkill"}} {{localize "MERC.Skills.melee"}}</span>
                </div>
                <button type="button" class="combat-base-skill-roll" data-skill="melee" title="{{localize "MERC.UI.combat.rollSkillCheck"}}">🎯</button>
                <div class="combat-base-damage-value">{{actor.system.combat.baseDamageMelee}}</div>
                <button type="button" class="combat-base-damage-roll" data-roll-formula="{{actor.system.combat.baseDamageMelee}}" data-roll-label="{{localize "MERC.Skills.melee"}}" title="{{localize "MERC.UI.combat.rollBaseDamage"}}">🎲</button>
              </div>
              <div class="combat-base-damage-row">
                <div class="combat-base-damage-label">
                  <span class="combat-base-damage-title">{{localize "MERC.UI.combat.baseDamageBladed"}}</span>
                  <span class="combat-base-damage-skill">{{localize "MERC.UI.combat.linkedSkill"}} {{localize "MERC.Skills.bladed_weapons"}}</span>
                </div>
                <button type="button" class="combat-base-skill-roll" data-skill="bladed_weapons" title="{{localize "MERC.UI.combat.rollSkillCheck"}}">🎯</button>
                <div class="combat-base-damage-value">{{actor.system.combat.baseDamageBladed}}</div>
                <button type="button" class="combat-base-damage-roll" data-roll-formula="{{actor.system.combat.baseDamageBladed}}" data-roll-label="{{localize "MERC.Skills.bladed_weapons"}}" title="{{localize "MERC.UI.combat.rollBaseDamage"}}">🎲</button>
              </div>
              {{#each actor.system.customSpecializations as |specData specName|}}
                {{#if (or (eq specData.baseSkill "melee") (eq specData.baseSkill "bladed_weapons"))}}
                <div class="combat-base-damage-row">
                  <div class="combat-base-damage-label">
                    <span class="combat-base-damage-title">{{#if (eq specData.baseSkill "melee")}}{{localize "MERC.UI.combat.baseDamageMelee"}}{{else}}{{localize "MERC.UI.combat.baseDamageBladed"}}{{/if}}</span>
                    <span class="combat-base-damage-skill">{{localize "MERC.UI.combat.linkedSkill"}} {{#if (eq specData.baseSkill "melee")}}{{localize "MERC.Skills.melee"}}{{else}}{{localize "MERC.Skills.bladed_weapons"}}{{/if}} : {{specName}}</span>
                  </div>
                  {{#with (concat "custom_spec_" specName) as |specKey|}}
                    <button type="button" class="combat-base-skill-roll" data-skill="{{specKey}}" title="{{localize "MERC.UI.combat.rollSkillCheck"}}">🎯</button>
                    <div class="combat-base-damage-value">
                      {{#if (lookup @root.actor.system.combat.specializationBaseDamage specKey)}}
                        {{lookup @root.actor.system.combat.specializationBaseDamage specKey}}
                      {{else}}
                        -
                      {{/if}}
                    </div>
                    <button type="button" class="combat-base-damage-roll" data-roll-formula="{{lookup @root.actor.system.combat.specializationBaseDamage specKey}}" data-roll-label="{{specName}}" title="{{localize "MERC.UI.combat.rollBaseDamage"}}">🎲</button>
                  {{/with}}
                </div>
                {{/if}}
              {{/each}}
            </div>
          </div>
        </div>

        <!-- One sub-tab per weapon -->
        {{#each (filterItems actor.items "weapon") as |item|}}
        <div class="combat-subtab-content" data-tab="combat-weapon-{{item._id}}">
          <div class="item-card item combat-weapon-card" data-item-id="{{item._id}}">

            <!-- Zone 1: titre — compétence + gestion -->
            <div class="combat-weapon-topbar">
              <div class="combat-weapon-skill-info">
                <span class="combat-weapon-skill-tag">{{localize "MERC.UI.combat.linkedSkill"}}</span>
                <span class="combat-weapon-skill-name">{{#if item.system.weaponSkill}}{{#if (lookup ../weaponSkillLabels item.system.weaponSkill)}}{{lookup ../weaponSkillLabels item.system.weaponSkill}}{{else}}{{item.system.weaponSkill}}{{/if}}{{else}}—{{/if}}</span>
              </div>
              <div class="combat-weapon-mgmt">
                <button type="button" class="item-edit" title="{{localize "MERC.UI.items.edit"}}">✎</button>
                <button type="button" class="item-delete" title="{{localize "MERC.UI.items.delete"}}"><i class="fas fa-trash"></i></button>
              </div>
            </div>

            <!-- Zones 2 + 3 côte à côte -->
            <div class="combat-weapon-body">

              <!-- Zone 2: jets de compétence -->
              <div class="combat-weapon-rolls">
                <button type="button" class="weapon-skill-roll combat-roll-btn" title="{{localize "MERC.UI.items.rollWeaponSkill"}}">
                  <span class="combat-roll-icon">🎯</span>
                  <span class="combat-roll-label">{{localize "MERC.UI.items.rollWeaponSkill"}}</span>
                </button>

              </div>

              <!-- Zone 3: dégâts (mélee) ou tableau munitions (armes à distance) -->
              {{#with (lookup ../weaponBallisticsMap item._id) as |wb|}}
              {{#if wb.isMeleeType}}
              <div class="combat-melee-damage">
                <div class="combat-melee-damage-header">
                  <span>{{localize "MERC.UI.items.weaponSheet.damage"}}</span>
                  <span>{{localize "MERC.UI.combat.baseDamageHeader"}}</span>
                  <span></span>
                </div>
                <div class="combat-melee-damage-row">
                  <span class="cam-col-dmg">{{#if wb.weaponDamage}}{{wb.weaponDamage}}{{else}}—{{/if}}</span>
                  <span class="cam-col-dmg">{{#if wb.baseDamageFormula}}+ {{wb.baseDamageFormula}}{{else}}—{{/if}}</span>
                  <button type="button" class="weapon-damage-roll cam-col-roll" title="{{localize "MERC.UI.items.rollWeaponDamage"}}">🎲</button>
                </div>
                {{#if wb.baseDamageLabel}}
                <div class="combat-melee-base-hint">{{localize "MERC.UI.combat.linkedSkill"}} {{wb.baseDamageLabel}}</div>
                {{/if}}
              </div>
              {{else}}
              <div class="combat-ammo-table">
                <div class="combat-ammo-table-header">
                  <span class="cam-col-name">{{localize "MERC.UI.items.ammo"}}</span>
                  <span class="cam-col-qty">{{localize "MERC.UI.items.ammoSheet.quantity"}}</span>
                  <span class="cam-col-dmg">{{localize "MERC.UI.items.weaponSheet.damage"}}</span>
                  <span class="cam-col-roll"></span>
                </div>
                {{#with this as |wb|}}
                  {{!-- Munition standard : affichée seulement si définie --}}
                  {{#if wb.default}}
                  <div class="combat-ammo-table-row cam-row-default" data-item-id="{{item._id}}">
                    <span class="cam-col-name cam-ammo-name-default">{{#if wb.defaultAmmoName}}{{wb.defaultAmmoName}}{{else}}Standard{{/if}}</span>
                    <span class="cam-col-qty">{{wb.defaultStock.inMag}}/{{#if wb.defaultStock.magCapacity}}{{wb.defaultStock.magCapacity}}{{else}}?{{/if}} - {{wb.defaultStock.magFull}}/{{wb.defaultStock.magTotal}} - {{wb.defaultStock.stock}}</span>
                    <span class="cam-col-dmg">{{wb.default.damage}}</span>
                    <button type="button" class="weapon-damage-roll cam-col-roll" data-roll-formula="{{wb.default.damage}}" title="{{localize "MERC.UI.items.rollWeaponDamage"}}">🎲</button>
                  </div>
                  <div class="combat-ammo-malus-row">
                    <span class="cam-malus-cell">
                      <span class="cam-range-dist"><span class="cam-malus-label">C</span>{{#if wb.ranges.short}} {{wb.ranges.short}}m{{/if}}</span>
                      {{#if (eq wb.default.blindage.short "-")}}<span class="cam-malus-none">—</span>{{else}}{{wb.default.blindage.short}}{{/if}}
                    </span>
                    <span class="cam-malus-cell">
                      <span class="cam-range-dist"><span class="cam-malus-label">M</span>{{#if wb.ranges.medium}} {{wb.ranges.medium}}m{{/if}}</span>
                      {{#if (eq wb.default.blindage.medium "-")}}<span class="cam-malus-none">—</span>{{else}}{{wb.default.blindage.medium}}{{/if}}
                    </span>
                    <span class="cam-malus-cell">
                      <span class="cam-range-dist"><span class="cam-malus-label">L</span>{{#if wb.ranges.long}} {{wb.ranges.long}}m{{/if}}</span>
                      {{#if (eq wb.default.blindage.long "-")}}<span class="cam-malus-none">—</span>{{else}}{{wb.default.blindage.long}}{{/if}}
                    </span>
                    <span class="cam-malus-cell">
                      <span class="cam-range-dist"><span class="cam-malus-label">X</span>{{#if wb.ranges.extreme}} {{wb.ranges.extreme}}m{{/if}}</span>
                      {{#if (eq wb.default.blindage.extreme "-")}}<span class="cam-malus-none">—</span>{{else}}{{wb.default.blindage.extreme}}{{/if}}
                    </span>
                  </div>
                  {{/if}}
                  {{!-- Munitions liées (ajoutées à l'acteur) --}}
                  {{#each wb.ammo as |ammoRow|}}
                  <div class="combat-ammo-table-row" data-item-id="{{ammoRow.id}}">
                    <span class="cam-col-name">{{ammoRow.name}}</span>
                    <span class="cam-col-qty">{{ammoRow.inMag}}/{{#if ammoRow.magCapacity}}{{ammoRow.magCapacity}}{{else}}?{{/if}} - {{ammoRow.magFull}}/{{ammoRow.magTotal}} - {{ammoRow.stock}}</span>
                    <span class="cam-col-dmg">{{#if ammoRow.ballistics}}{{ammoRow.ballistics.damage}}{{else}}—{{/if}}</span>
                    <button type="button" class="weapon-damage-roll cam-col-roll" data-roll-formula="{{#if ammoRow.ballistics}}{{ammoRow.ballistics.damage}}{{/if}}" title="{{localize "MERC.UI.items.rollWeaponDamage"}}">🎲</button>
                  </div>
                  {{#if ammoRow.ballistics}}
                  <div class="combat-ammo-malus-row">
                    <span class="cam-malus-cell">
                      <span class="cam-range-dist"><span class="cam-malus-label">C</span>{{#if wb.ranges.short}} {{wb.ranges.short}}m{{/if}}</span>
                      {{#if (eq ammoRow.ballistics.blindage.short "-")}}<span class="cam-malus-none">—</span>{{else}}{{ammoRow.ballistics.blindage.short}}{{/if}}
                    </span>
                    <span class="cam-malus-cell">
                      <span class="cam-range-dist"><span class="cam-malus-label">M</span>{{#if wb.ranges.medium}} {{wb.ranges.medium}}m{{/if}}</span>
                      {{#if (eq ammoRow.ballistics.blindage.medium "-")}}<span class="cam-malus-none">—</span>{{else}}{{ammoRow.ballistics.blindage.medium}}{{/if}}
                    </span>
                    <span class="cam-malus-cell">
                      <span class="cam-range-dist"><span class="cam-malus-label">L</span>{{#if wb.ranges.long}} {{wb.ranges.long}}m{{/if}}</span>
                      {{#if (eq ammoRow.ballistics.blindage.long "-")}}<span class="cam-malus-none">—</span>{{else}}{{ammoRow.ballistics.blindage.long}}{{/if}}
                    </span>
                    <span class="cam-malus-cell">
                      <span class="cam-range-dist"><span class="cam-malus-label">X</span>{{#if wb.ranges.extreme}} {{wb.ranges.extreme}}m{{/if}}</span>
                      {{#if (eq ammoRow.ballistics.blindage.extreme "-")}}<span class="cam-malus-none">—</span>{{else}}{{ammoRow.ballistics.blindage.extreme}}{{/if}}
                    </span>
                  </div>
                  {{/if}}
                  {{/each}}
                {{/with}}
              </div>
              {{/if}}
              {{/with}}

            </div>

            {{!-- Accessoires (features) attachés à cette arme --}}
            {{#with (lookup ../weaponBallisticsMap item._id) as |wb|}}
            {{#if wb.features}}
            <div class="combat-weapon-features">
              <div class="combat-weapon-features-title">{{localize "MERC.UI.combat.featuresTitle"}}</div>
              {{#each wb.features as |feat|}}
              <div class="combat-feature-row">
                <span class="cfr-name">{{feat.name}}</span>
                {{#if feat.featureType}}<span class="cfr-type">{{feat.featureType}}</span>{{/if}}
                <div class="cfr-bonuses">
                  {{#if feat.bonusShortRange}}<span class="cfr-tag">C: +{{feat.bonusShortRange}}</span>{{/if}}
                  {{#if feat.bonusMediumRange}}<span class="cfr-tag">M: +{{feat.bonusMediumRange}}</span>{{/if}}
                  {{#if feat.bonusLongRange}}<span class="cfr-tag">L: +{{feat.bonusLongRange}}</span>{{/if}}
                  {{#if feat.bonusExtremeRange}}<span class="cfr-tag">X: +{{feat.bonusExtremeRange}}</span>{{/if}}
                  {{#if feat.noiseReduction}}<span class="cfr-tag cfr-noise">🔇 {{feat.noiseReduction}}</span>{{/if}}
                  {{#if feat.lateralNoiseReduction}}<span class="cfr-tag cfr-noise">🔇↔ {{feat.lateralNoiseReduction}}</span>{{/if}}
                  {{#if feat.lengthIncreaseCm}}<span class="cfr-tag cfr-len">+{{feat.lengthIncreaseCm}}cm</span>{{/if}}
                </div>
              </div>
              {{/each}}
            </div>
            {{/if}}
            {{/with}}

          </div>
        </div>
        {{/each}}

      </section>

    </div>

    <!-- ITEMS TAB -->
    <div class="tab-content" data-tab="items">
      
      <!-- Weapons -->
      <div class="items-section">
        <h3><div class="items-header"><span>{{localize "MERC.UI.items.weapons"}}</span><button type="button" class="item-create btn" data-type="weapon">{{localize "MERC.UI.items.addWeapon"}}</button></div></h3>
        <div class="items-list">
          {{#each (filterItems actor.items "weapon") as |item|}}
          <div class="item-card item" data-item-id="{{item._id}}">
            <div class="item-info">
              <div class="item-name">{{item.name}}{{#if (eq item.system.proficiency 1)}}<span class="proficiency-star">★</span>{{/if}}</div>
              <div class="item-damage-skill">{{localize "MERC.UI.combat.linkedSkill"}} {{#if item.system.weaponSkill}}{{#if (lookup ../weaponSkillLabels item.system.weaponSkill)}}{{lookup ../weaponSkillLabels item.system.weaponSkill}}{{else}}{{item.system.weaponSkill}}{{/if}}{{else}}-{{/if}}</div>
            </div>
            <div class="item-controls">
              <button type="button" class="item-edit">✎</button>
              <button type="button" class="item-delete"><i class="fas fa-trash"></i></button>
            </div>
          </div>
          {{/each}}
        </div>
      </div>

      <!-- Armor -->
      <div class="items-section">
        <h3><div class="items-header"><span>{{localize "MERC.UI.items.armor"}}</span><button type="button" class="item-create btn" data-type="armor">{{localize "MERC.UI.items.addArmor"}}</button></div></h3>
        <div class="items-list">
          {{#each (filterItems actor.items "armor") as |item|}}
          <div class="item-card item" data-item-id="{{item._id}}">
            <div class="item-info">
              <div class="item-name">{{item.name}}</div>
              <div class="item-damage-skill">{{localize "MERC.UI.items.armorClassShort"}} {{item.system.armorClass}}</div>
            </div>
            <div class="item-controls">
              <button type="button" class="item-edit">✎</button>
              <button type="button" class="item-delete"><i class="fas fa-trash"></i></button>
            </div>
          </div>
          {{/each}}
        </div>
      </div>

      <!-- Equipment -->
      <div class="items-section">
