    </div>

    <!-- CREW TAB -->
    <div class="tab-content" data-tab="crew">
      <div class="crew-section">
        <div class="crew-header">
          <h3>{{localize "MERC.Vehicle.crewTitle"}}</h3>
        </div>
        <div class="crew-drop-zone">
          <p class="crew-drop-hint">{{localize "MERC.Vehicle.crewDropHint"}}</p>
          <div class="crew-list">
            {{#each crewMembers as |member|}}
            <div class="crew-member-card" data-member-id="{{member.id}}">
              <img class="crew-portrait" src="{{member.img}}" alt="{{member.name}}">
              <div class="crew-info">
                <div class="crew-name">{{member.name}}</div>
                {{#each member.assignments as |assignment|}}
                <div class="crew-assignment-row" data-assignment-index="{{@index}}">
                  <select class="crew-role-select">
                    <option value="pilot" {{#eq assignment.type "pilot"}}selected{{/eq}}>{{localize "MERC.Vehicle.crewRoles.pilot"}}</option>
                    <option value="gunner" {{#eq assignment.type "gunner"}}selected{{/eq}}>{{localize "MERC.Vehicle.crewRoles.gunner"}}</option>
                    <option value="passenger" {{#eq assignment.type "passenger"}}selected{{/eq}}>{{localize "MERC.Vehicle.crewRoles.passenger"}}</option>
                  </select>
                  {{#eq assignment.type "gunner"}}
                  <select class="crew-weapon-select" title="{{localize "MERC.Vehicle.crewWeaponSelect"}}">
                    <option value="">{{localize "MERC.Vehicle.crewWeaponPlaceholder"}}</option>
                    {{#each ../../vehicleWeapons as |weapon|}}
                    <option value="{{weapon.id}}" {{#eq weapon.id assignment.weaponId}}selected{{/eq}}>{{weapon.name}}</option>
                    {{/each}}
                  </select>
                  <button type="button" class="crew-skill-roll" title="{{localize "MERC.Vehicle.crewRollSkill"}}">🎯</button>
                  {{#if assignment.damage}}
                  <span class="crew-damage-value">{{assignment.damage}}</span>
                  <button type="button" class="crew-damage-roll" data-roll-formula="{{assignment.damageFormula}}" title="{{localize "MERC.Vehicle.crewRollDamage"}}">🎲</button>
                  {{/if}}
                  {{/eq}}
                  {{#eq assignment.type "pilot"}}
                  <button type="button" class="crew-skill-roll" title="{{localize "MERC.Vehicle.crewRollSkill"}}">🛞</button>
                  {{/eq}}
                  <button type="button" class="crew-assignment-remove" title="{{localize "MERC.Vehicle.crewRemoveAssignment"}}">✕</button>
                </div>
                {{/each}}
                <button type="button" class="crew-assignment-add" title="{{localize "MERC.Vehicle.crewAddRole"}}">+ {{localize "MERC.Vehicle.crewAddRole"}}</button>
              </div>
              <button type="button" class="crew-remove" title="{{localize "MERC.Vehicle.crewRemove"}}">
                <i class="fas fa-trash"></i>
              </button>
            </div>
            {{/each}}
          </div>
        </div>
      </div>
    </div>

    <!-- CARGO TAB -->
    <div class="tab-content" data-tab="cargo">
      <div class="cargo-section">
        <div class="cargo-drop-zone">
          <p class="cargo-drop-hint">{{localize "MERC.Vehicle.cargoDropHint"}}</p>
          {{#each cargoCategories as |cat|}}
          {{#if cat.items.length}}
          <div class="cargo-category">
            <div class="cargo-category-header">
              <span class="cargo-category-label">{{cat.label}}</span>
            </div>
            <div class="items-list">
              {{#each cat.items as |item|}}
              <div class="item-card item" data-item-id="{{item._id}}">
                <img class="cargo-item-icon" src="{{item.img}}" alt="{{item.name}}">
                <div class="item-info">
                  <div class="item-name">{{item.name}}</div>
                  {{#if item.system.quantity}}<div class="item-sub">x{{item.system.quantity}}</div>{{/if}}
                </div>
                <div class="item-controls">
                  <button type="button" class="item-edit">✎</button>
                  <button type="button" class="item-delete"><i class="fas fa-trash"></i></button>
                </div>
              </div>
              {{/each}}
            </div>
          </div>
          {{/if}}
          {{/each}}

          {{#if cargoStorages.length}}
          <div class="cargo-category cargo-storage-category">
            <div class="cargo-category-header">
              <span class="cargo-category-label">{{localize "MERC.UI.items.storage"}}</span>
            </div>
            {{#each cargoStorages as |stor|}}
            <div class="storage-card item" data-item-id="{{stor._id}}">
              <div class="storage-card-header">
                <img class="cargo-item-icon" src="{{stor.img}}" alt="{{stor.name}}">
                <span class="storage-card-name">{{stor.name}}</span>
                <span class="storage-weight-info {{#if stor.isOverCapacity}}over-capacity{{/if}}">
                  {{stor.usedWeight}} / {{stor.system.capacityKg}} kg
                </span>
                <div class="item-controls">
                  <button type="button" class="storage-toggle-btn" data-storage-id="{{stor._id}}">▸</button>
                  <button type="button" class="item-edit">✎</button>
                  <button type="button" class="item-delete"><i class="fas fa-trash"></i></button>
                </div>
              </div>
              <div class="storage-contents" data-storage-id="{{stor._id}}">
                <div class="storage-inner-drop" data-storage-id="{{stor._id}}">
                  {{#if stor.contents.length}}
                  <div class="items-list">
                    {{#each stor.contents as |ci|}}
                    <div class="item-card item" data-item-id="{{ci._id}}">
                      <img class="cargo-item-icon" src="{{ci.img}}" alt="{{ci.name}}">
                      <div class="item-info">
                        <div class="item-name">{{ci.name}}</div>
                        <div class="item-sub">{{ci.system.weightKg}} kg</div>
                      </div>
                      <div class="item-controls">
                        <button type="button" class="storage-item-remove-btn" data-item-id="{{ci._id}}" title="{{localize "MERC.UI.items.storageSheet.removeFromStorage"}}">⤴</button>
                        <button type="button" class="item-edit">✎</button>
                        <button type="button" class="item-delete"><i class="fas fa-trash"></i></button>
                      </div>
                    </div>
                    {{/each}}
                  </div>
                  {{else}}
                  <p class="storage-drop-hint">{{localize "MERC.UI.items.storageSheet.dropHint"}}</p>
                  {{/if}}
                </div>
              </div>
            </div>
            {{/each}}
          </div>
          {{/if}}

          <div class="cargo-add-buttons">
            {{#each cargoCategories as |cat|}}
            <button type="button" class="item-create btn cargo-add-btn" data-type="{{cat.type}}" data-is-cargo="true">+ {{cat.label}}</button>
            {{/each}}
            <button type="button" class="item-create btn cargo-add-btn" data-type="storage" data-is-cargo="true">+ {{localize "MERC.UI.items.storage"}}</button>
          </div>
        </div>
      </div>
    </div>

    <!-- DESCRIPTION TAB -->
    <div class="tab-content{{#if isLimited}} active{{/if}}" data-tab="description">
      <div class="notes-section">
        <textarea class="notes-textarea" name="system.description" rows="16" placeholder="{{localize "MERC.Labels.descriptionPlaceholder"}}">{{actor.system.description}}</textarea>
      </div>
    </div>

    <!-- NOTES TAB -->
    <div class="tab-content" data-tab="notes">
      <div class="notes-section">
