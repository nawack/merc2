      <!-- Weapons Management List -->
      <div class="items-section">
        <h3>
          <div class="items-header">
            <span>{{localize "MERC.UI.items.weapons"}}</span>
            <button type="button" class="item-create btn" data-type="weapon">+ {{localize "MERC.UI.items.addWeapon"}}</button>
          </div>
        </h3>
        <div class="items-list">
          {{#each vehicleWeaponItems as |item|}}
          <div class="item-card item" data-item-id="{{item._id}}">
            <div class="item-info">
              <div class="item-name">{{item.name}}{{#if (eq item.system.proficiency 1)}}<span class="proficiency-star">★</span>{{/if}}</div>
              <div class="item-damage-skill">{{localize "MERC.UI.combat.linkedSkill"}} {{#if item.system.weaponSkill}}{{#if (lookup ../weaponSkillLabels item.system.weaponSkill)}}{{lookup ../weaponSkillLabels item.system.weaponSkill}}{{else}}{{item.system.weaponSkill}}{{/if}}{{else}}-{{/if}}</div>
            </div>
            <div class="item-controls">
              <button type="button" class="item-edit">✎</button>
              <button type="button" class="item-delete"><i class="fas fa-trash"></i></button>
            </div>
          </div>
          {{/each}}
        </div>
      </div>

      <!-- Ammo Management List -->
      <!--
